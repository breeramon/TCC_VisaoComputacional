# ==========================================
# .gitignore - TCC Visão Computacional
# ==========================================

# Ambientes Virtuais (Nunca subir para o GitHub)
.venv/
venv/
env/

# Arquivos de Cache do Python
__pycache__/
*.pyc

# Modelos Pesados de IA (YOLO)
*.pt
*.onnx
modelos/yolo_pt/*
modelos/yolo_tflite/*

# Flutter
app_mobile/.dart_tool/
app_mobile/build/
app_mobile/.flutter-plugins
app_mobile/.flutter-plugins-dependencies

# Arquivos gerados pela exportação TFLite
*_saved_model/                          # Pasta TensorFlow SavedModel (~107MB), intermediário da exportação
calibration_image_sample_data_*.npy     # Dados de calibração baixados automaticamente pelo Ultralytics
calibration_image_sample_data_*.npy.zip

# Imagens e Vídeos de Teste (Evita lotar o repositório)
dados/brutos/*
dados/anotados/*

# Arquivos de sistema operacional
.DS_Store
Thumbs.db